generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

// Note: SQL Server connector does not support Prisma enums.
// Using a string `status` column with a default value instead.
model Region {
  id Int @id(map: "PK__regions__01146BAEBE221DD1") @default(autoincrement()) @map("region_id")

  // Dual language support with NVarChar
  nameAmharic String @unique @map("region_name_am") @db.NVarChar(150)
  nameEnglish String @unique @map("region_name_en") @db.VarChar(150) // English characters stay safe in standard VarChar

  zones Zone[]

  @@map("regions")
}

model Zone {
  id       Int @id(map: "PK__zones__80B401DF6769EBAD") @default(autoincrement()) @map("zone_id")
  regionId Int @map("region_id")

  nameAmharic String @map("zone_name_am") @db.NVarChar(100)
  nameEnglish String @map("zone_name_en") @db.VarChar(100)

  woredas Woreda[]
  region  Region   @relation(fields: [regionId], references: [id], onUpdate: NoAction, map: "FK_Zones_Regions")

  @@map("zones")
}

model Woreda {
  id     Int @id(map: "PK__woredas__024DE9E7AD1B218E") @default(autoincrement()) @map("woreda_id")
  zoneId Int @map("zone_id")

  nameAmharic String @map("woreda_name_am") @db.NVarChar(100)
  nameEnglish String @map("woreda_name_en") @db.VarChar(100)

  kebeles Kebele[]
  zone    Zone     @relation(fields: [zoneId], references: [id], onUpdate: NoAction, map: "FK_Woredas_Zones")

  @@map("woredas")
}

model Kebele {
  id       Int @id(map: "PK__kebeles__E44A705322F18FA2") @default(autoincrement()) @map("kebele_id")
  woredaId Int @map("woreda_id")

  nameAmharic String @map("kebele_name_am") @db.NVarChar(100)
  nameEnglish String @map("kebele_name_en") @db.VarChar(100)

  addresses             Address[]
  woreda                Woreda                             @relation(fields: [woredaId], references: [id], onUpdate: NoAction, map: "FK_Kebeles_Woredas")
  addressChangeRequests OrganizationAddressChangeRequest[]

  @@map("kebeles")
}

model Address {
  id          Int     @id(map: "PK__addresse__CAA247C865086651") @default(autoincrement()) @map("address_id")
  kebeleId    Int     @map("kebele_id")
  houseNumber String? @map("house_number") @db.VarChar(50) // House numbers stay standard alphanumerics

  // Special locations often hold descriptive Ge'ez pointers (e.g., "ከሀረማያ ዩኒቨርሲቲ ጀርባ")
  specialLocation String? @map("special_location") @db.NVarChar(Max)

  kebele           Kebele               @relation(fields: [kebeleId], references: [id], onUpdate: NoAction, map: "FK_Addresses_Kebeles")
  organizations    Organization[]
  branches         OrganizationBranch[]
  employees        Employee[]
  serviceContracts ServiceContract[]

  @@map("addresses")
}

// Global Authority Identity (Singleton)
model SystemSettings {
  id               Int    @id @default(1)
  governmentName   String @default("Ethiopian Federal Police")
  efpLogoUrl       String @map("efp_logo_url") @db.VarChar(Max)
  issuingAuthority String @default("Private Security Agency Management Directorate") @map("issuing_authority")

  @@map("system_settings")
}

model User {
  id         Int          @id(map: "PK__users__B9BE370FAA48DD8D") @default(autoincrement()) @map("user_id")
  username   String       @unique(map: "UQ__users__F3DBC572ABE5C56B") @db.VarChar(100)
  fullName   String       @map("full_name") @db.VarChar(255)
  email      String       @unique(map: "UQ__users__20C6DFF5E0E57950") @map("email_address") @db.VarChar(255)
  phone      String       @unique(map: "UQ__users__A1936A6BBE0D0FB3") @map("phone_number") @db.VarChar(50)
  password   String       @map("password_hash") @db.VarChar(Max)
  faydaId    String       @unique // Add this line
  photoUrl   String?      @map("photo_url") @db.VarChar(Max)
  createdAt  DateTime?    @default(now(), map: "DF__users__account_c__6E01572D") @map("account_created_at") @db.DateTime
  status     String       @default("ACTIVE") @map("status") @db.VarChar(20)
  user_roles user_roles[]

  // Add these back-relation fields:
  initiatedTransfers         TransferRequest[]            @relation("TransferInitiator")
  actionedTransfers          TransferRequest[]            @relation("TransferActioner")
  official                   Official?
  applications               Application[] // Fixes the missing opposite relation error
  formalRequests             FormalRequest[]
  auditLogs                  AuditLog[]                   @relation("UserAuditLogs")
  employee                   Employee?
  inspections                Inspection[]                 @relation("LeadInspector")
  incidentReports            IncidentReport[]             @relation("IncidentReporter")
  historyLogs                ApplicationTrackingHistory[]
  inspectionCommittees       InspectionCommittee[]
  createdFaqs                Faq[]                        @relation("FaqCreator")
  notifications              Notification[]
  certifications             Certification[]              @relation("CertificationStampedBy")
  receivedContacts           Contact[]
  newsArticles               NewsArticle[]
  initiatedPersonnelRequests PersonnelChangeRequest[]     @relation("HRManagerInitiator")
  createdPeriodReports       RegularPeriodReport[]        @relation("PeriodReportCreator")
  approvedPeriodReports      RegularPeriodReport[]        @relation("PeriodReportSuperior")

  @@map("users")
}

model FederalPolicePosition {
  id          Int        @id @default(autoincrement()) @map("efp_position_id")
  nameEnglish String     @map("en_name") @db.NVarChar(100)
  nameAmharic String     @map("am_name") @db.NVarChar(100)
  officials   Official[]

  @@unique([nameEnglish, nameAmharic])
  @@map("federal_police_positions")
}

model Official {
  id            Int      @id @default(autoincrement()) @map("official_id")
  userId        Int      @unique @map("user_id") // Links to User.id
  efpPositionId Int      @map("position_id")
  fullNameAm    String   @map("full_name_am") @db.NVarChar(250)
  signatureUrl  String?  @map("signature_url") @db.VarChar(MAX) // Use MAX if using SQL Server
  stampUrl      String?  @map("stamp_url") @db.VarChar(MAX) // Use MAX if using SQL Server
  isStamped     Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  position       FederalPolicePosition @relation(fields: [efpPositionId], references: [id])
  user           User                  @relation(fields: [userId], references: [id])
  certifications Certification[]

  @@map("officials")
}

model roles {
  role_id    Int          @id(map: "PK__roles__760965CC3D9EF01F") @default(autoincrement())
  role_name  String       @unique(map: "UQ__roles__783254B107AC82B7") @db.VarChar(100)
  user_roles user_roles[]
}

model user_roles {
  user_id Int
  role_id Int
  roles   roles @relation(fields: [role_id], references: [role_id], onDelete: Cascade, onUpdate: NoAction, map: "FK_UserRoles_Roles")
  users   User  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_UserRoles_Users")

  @@id([user_id, role_id], map: "PK_UserRoles")
}

model Notification {
  id                Int      @id @default(autoincrement()) @map("notification_id")
  recipientUserId   Int      @map("recipient_user_id") // Target user being notified
  notificationType  String   @map("notification_type") @db.VarChar(50) // APPROVED, REJECTED, INSPECTION, EXPIRY_30, CRITICAL, etc.
  alertTitle        String   @map("alert_title") @db.NVarChar(255)
  alertMessage      String   @map("alert_message") @db.NVarChar(Max)
  isReadByRecipient Boolean  @default(false) @map("is_read_by_recipient")
  createdAt         DateTime @default(now()) @map("created_at") @db.DateTime
  // Relations
  recipientUser     User     @relation(fields: [recipientUserId], references: [id], onDelete: Cascade, map: "FK_Notifications_Users")

  @@map("notifications")
}

model NewsArticle {
  id              Int      @id @default(autoincrement()) @map("news_id")
  title           String   @db.NVarChar(255)
  titleAm         String?  @map("title_am") @db.NVarChar(255)
  category        String   @default("General") @db.NVarChar(100)
  summary         String?  @db.NVarChar(Max)
  summaryAm       String?  @map("summary_am") @db.NVarChar(Max)
  content         String   @db.NVarChar(Max)
  contentAm       String?  @map("content_am") @db.NVarChar(Max)
  imageUrl        String?  @map("image_url") @db.VarChar(Max)
  status          String   @default("published") @db.VarChar(50)
  publishedAt     DateTime @default(now()) @map("published_at")
  createdByUserId Int?     @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdBy User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "FK_News_Users")

  @@map("news_articles")
}

model FormalRequest {
  id               Int      @id @default(autoincrement())
  userId           Int
  user             User     @relation(fields: [userId], references: [id])
  requestLetterUrl String
  status           String   @default("PENDING") // PENDING, APPROVED, REJECTED
  adminFeedback    String?  @db.VarChar(Max)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("formal_requests")
}

model Organization {
  id          Int     @id @default(autoincrement()) @map("organization_id")
  nameAmharic String  @unique @map("organization_name_am") @db.NVarChar(255)
  nameEnglish String  @unique @map("organization_name_en") @db.VarChar(255)
  email       String  @unique @map("email_address") @db.VarChar(255)
  phone       String  @map("phone_number") @db.VarChar(50)
  faxNumber   String? @map("fax_number") @db.VarChar(50)
  tradeName   String? @unique @map("trade_name") @db.NVarChar(255)
  tinNumber   String  @unique @map("tin_number") @db.VarChar(50)
  addressId   Int?    @map("address_id")

  // Resource Tracking (Step 3)
  numberOfOffices   Int?     @map("number_of_offices")
  numberOfVehicles  Int?     @map("number_of_vehicles")
  numberOfComputers Int?     @map("number_of_computers")
  hasStoreHouse     Boolean  @default(false) @map("has_store_house")
  capitalAmount     Decimal? @map("capital_amount") @db.Decimal(18, 2)

  // Status & Metadata

  status    String?  @default("Pending") @map("organization_status") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime

  // Relations
  sourceTransfers       TransferRequest[]                  @relation("SourceTransfers")
  targetTransfers       TransferRequest[]                  @relation("TargetTransfers")
  address               Address?                           @relation(fields: [addressId], references: [id], onUpdate: NoAction, map: "FK_Organizations_Addresses")
  branches              OrganizationBranch[]
  documents             OrganizationDocument[]
  employees             Employee[]
  applications          Application[]
  regularPeriodReports  RegularPeriodReport[]
  certifications        Certification[]
  renewalApplications   RenewalApplication[]
  guardEducationStats   GuardEducationLevelStat[]
  incidents             IncidentReport[]
  // agreements now relate through applications
  serviceContracts      ServiceContract[]
  addressChangeRequests OrganizationAddressChangeRequest[]

  @@map("organizations")
}

model OrganizationBranch {
  id             Int @id @default(autoincrement()) @map("branch_id")
  organizationId Int @map("organization_id")
  addressId      Int @map("address_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Branches_Organizations")
  address      Address      @relation(fields: [addressId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Branches_Addresses")

  @@map("organization_branches")
}

// The new Request Model
model OrganizationAddressChangeRequest {
  addressRequestId         Int     @id @default(autoincrement()) @map("address_request_id")
  organizationId           Int     @map("organization_id")
  requestedKebeleId        Int     @map("requested_kebele_id")
  requestedHouseNumber     String? @map("requested_house_number") @db.VarChar(50)
  requestedSpecialLocation String? @map("requested_special_location") @db.NVarChar(Max)

  reason        String? @db.NVarChar(Max) // Why they want to change
  adminFeedback String? @map("admin_feedback") @db.NVarChar(Max)
  status        String? @default("PENDING") @map("request_status") @db.VarChar(50)

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  // Relations
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedKebele Kebele       @relation(fields: [requestedKebeleId], references: [id], onUpdate: NoAction)

  @@map("org_address_change_requests")
}

model ServiceContract {
  id                     Int    @id @default(autoincrement()) @map("contract_id")
  organizationId         Int    @map("organization_id") // Foreign key to Organization table
  serviceUserName        String @map("service_user_name") @db.NVarChar(255) // The specific client/user name (e.g., Ethio Logistics PLC)
  contractUrl            String @map("contract_url") @db.VarChar(Max) // Digital contract document link
  addressId              Int    @map("address_id") // Foreign key to Address table
  assignedPersonnelCount Int    @map("assigned_personnel_count")

  // Lifecycle & Status Management
  // Recommended values: "Active", "Expired", "Terminated", "Pending_Renewal"
  status       String    @default("Active") @map("contract_status") @db.VarChar(50)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime
  terminatedAt DateTime? @map("Terminated_at") @db.DateTime
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.DateTime

  // Explicit NoAction rules keep SQL Server happy by avoiding loop collisions
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Contracts_Organizations")
  address      Address      @relation(fields: [addressId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Contracts_Addresses")

  @@map("service_contracts")
}

model Agreement {
  id              Int    @id @default(autoincrement()) @map("agreement_id")
  agreementNumber String @unique @map("agreement_number") @db.VarChar(100)
  applicationId   Int?   @map("application_id")
  status          String @default("Pending") @map("agreement_status") @db.VarChar(50)

  // FIXED: Changed from Json to VarChar(Max) for SQL Server stringified compatibility
  snapshotData String @map("snapshot_data") @db.NVarChar(Max)

  recruitmentDeadline DateTime @map("recruitment_deadline") @db.DateTime
  issuedDate          DateTime @default(now()) @map("issued_date") @db.DateTime
  expiryDate          DateTime @map("expiry_date") @db.DateTime
  createdAt           DateTime @default(now()) @map("created_at") @db.DateTime
  updatedAt           DateTime @updatedAt @map("updated_at") @db.DateTime

  // FIXED: Changed onDelete from Restrict to NoAction for SQL Server compatibility
  application Application? @relation(fields: [applicationId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Agreements_Applications")

  @@index([applicationId, issuedDate])
  @@map("agreements")
}

model OrganizationDocument {
  id             Int          @id @default(autoincrement()) @map("org_doc_id")
  organizationId Int          @map("organization_id")
  documentType   String       @map("document_type") @db.VarChar(50)
  fileUrl        String       @map("file_url") @db.VarChar(Max)
  isVerified     Boolean      @default(false) @map("is_verified")
  verifiedAt     DateTime?    @map("verified_at") @db.DateTime
  issuedDate     DateTime?    @map("issue_date") @db.Date
  expiryDate     DateTime?    @map("expiry_date") @db.Date
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "FK_OrgDocs_Organizations")

  @@map("organization_documents")
}

// ==========================================
// 3. HRMS: EMPLOYEES, POSITIONS & DOCS
// ==========================================

model Employee {
  id                  Int       @id @default(autoincrement()) @map("employee_id")
  userId              Int       @unique @map("user_id")
  organizationId      Int       @map("organization_id")
  positionId          Int?      @map("position_id") // Made optional (?) in case onboarding hasn't assigned a position yet
  addressId           Int?      @map("address_id")
  gender              String?   @db.VarChar(20)
  citizenship         String?   @db.VarChar(100)
  age                 Int?
  educationLevel      String?   @map("education_level") @db.VarChar(100)
  workExpYears        Int       @default(0) @map("work_experience_years")
  TotalExpYears       Int       @default(0) @map("total_experience_years")
  isBlacklisted       Boolean   @default(false) @map("is_blacklisted")
  employmentStatus    String?   @map("employment_status") @db.VarChar(50)
  employmentStartDate DateTime? @map("employment_start_date") @db.Date

  // Core Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade, map: "FK_Employees_Users")
  organization Organization @relation(fields: [organizationId], references: [id], onUpdate: NoAction, map: "FK_Employees_Organizations")
  address      Address?     @relation(fields: [addressId], references: [id], onUpdate: NoAction, map: "FK_Employees_Addresses")

  // Existing Module Relations
  position  Position?          @relation(fields: [positionId], references: [id], onUpdate: NoAction, map: "FK_Employees_Positions")
  documents EmployeeDocument[]

  // Application Tracking Roles
  managedApplications    Application[] @relation("ManagerRole")
  operationsApplications Application[] @relation("OperationsHeadRole")
  adminApplications      Application[] @relation("AdminHeadRole")

  // ADDED: Required back-relations for Incident and Manager Change modules
  transferRequests          TransferRequest[]
  suspectedIncidents        IncidentSuspect[]
  targetedPersonnelRequests PersonnelChangeRequest[] @relation("TargetEmployeeRecord")

  @@map("employees")
}

model PersonnelChangeRequest {
  id Int @id @default(autoincrement()) @map("person_change_request_id")

  // Discriminator field: "NEW_EMPLOYEE" or "EXISTING_EMPLOYEE"
  requestType String @map("request_type") @db.VarChar(40)

  // Who is creating the request (The logged-in HR Manager)
  initiatedByUserId Int  @map("initiated_by_user_id")
  initiator         User @relation("HRManagerInitiator", fields: [initiatedByUserId], references: [id], onUpdate: NoAction)

  // Target Employee: The target employee being changed (Always points to the core table)
  targetEmployeeId Int      @map("target_employee_id")
  targetEmployee   Employee @relation("TargetEmployeeRecord", fields: [targetEmployeeId], references: [id], onDelete: Cascade)

  // Track original deployment source vs requested deployment destination
  sourceOrganizationId Int @map("source_organization_id")
  targetOrganizationId Int @map("target_organization_id")

  // Justification & Review Notes
  reason        String  @map("change_reason") @db.NVarChar(Max) // The HR Manager's justification for the request
  adminFeedback String? @map("admin_feedback") @db.NVarChar(Max) // Explains why an admin rejected or commented on the request

  targetPositionId Int @map("target_position_id")

  // Status tracking metadata
  status    String   @default("PENDING") @db.VarChar(30) // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("personnel_change_requests")
}

model TransferRequest {
  id                   Int  @id @default(autoincrement()) @map("request_id")
  employeeId           Int  @map("employee_id")
  sourceOrganizationId Int  @map("source_organization_id")
  targetOrganizationId Int  @map("target_organization_id")
  requestedPositionId  Int? @map("requested_position_id")

  // Workflow States: PENDING, AGENCY_B_PRE_APPROVED, FULLY_APPROVED, REJECTED
  status          String  @default("PENDING") @db.VarChar(50)
  reason          String  @map("transfer_reason") @db.VarChar(Max)
  rejectionReason String? @map("rejection_reason") @db.VarChar(Max)

  // Audit Tracking
  initiatedById Int       @map("initiated_by_user_id") // HR Manager from Agency A who clicked send
  actionedById  Int?      @map("actioned_by_user_id") // HR Manager from Agency B who clicked approve
  createdAt     DateTime  @default(now()) @map("created_at") @db.DateTime
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.DateTime
  actionedAt    DateTime? @map("actioned_at") @db.DateTime

  // Relations (Explicitly protected against cascading loops)
  employee           Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "FK_Transfers_Employees")
  sourceOrganization Organization @relation("SourceTransfers", fields: [sourceOrganizationId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Transfers_SourceOrg")
  targetOrganization Organization @relation("TargetTransfers", fields: [targetOrganizationId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Transfers_TargetOrg")
  position           Position?    @relation(fields: [requestedPositionId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Transfers_Positions")
  initiatedBy        User         @relation("TransferInitiator", fields: [initiatedById], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Transfers_Initiator")
  actionedBy         User?        @relation("TransferActioner", fields: [actionedById], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Transfers_Actioner")

  @@map("employee_transfer_requests")
}

model Position {
  id               Int                   @id @default(autoincrement()) @map("position_id")
  name             String                @unique @map("position_name") @db.VarChar(100)
  requirements     PositionRequirement[]
  employees        Employee[]
  transferRequests TransferRequest[]

  @@map("positions")
}

model PositionRequirement {
  id                          Int      @id @default(autoincrement()) @map("position_requirement_id")
  positionId                  Int      @map("position_id")
  level                       Int?     @map("level")
  requiredEducationLevel      String?  @map("required_education_level") @db.VarChar(100)
  minimumExperienceYears      Int?     @map("minimum_experience_years")
  requiredWorkExperienceYears Int?     @map("required_work_experience_years")
  position                    Position @relation(fields: [positionId], references: [id], onDelete: Cascade, map: "FK_PosReq_Positions")

  @@map("position_requirements")
}

// ==========================================
// DOCUMENTATION MODELS
// ==========================================

model EmployeeDocument {
  id           Int       @id @default(autoincrement()) @map("document_id")
  employeeId   Int       @map("employee_id")
  documentType String    @map("document_type") @db.VarChar(100)
  fileUrl      String    @map("document_file_url") @db.VarChar(Max)
  isVerified   Boolean   @default(false) @map("is_verified")
  verifiedAt   DateTime? @map("verified_at") @db.DateTime
  uploadedAt   DateTime  @default(now()) @map("uploaded_at") @db.DateTime

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "FK_EmpDocs_Employees")

  @@map("employee_documents")
}

// ==========================================
// 4. APPLICATIONS & TRACKING
// ==========================================

model Application {
  id               Int          @id @default(autoincrement()) @map("application_id")
  userId           Int          @map("user_id")
  organizationId   Int          @map("organization_id")
  type             String?      @map("application_type") @db.VarChar(50)
  status           String?      @map("application_status") @db.VarChar(50)
  managerId        Int?         @map("manager_id")
  operationsHeadId Int?         @map("operations_head_id")
  adminHeadId      Int?         @map("admin_head_id")
  applicationDate  DateTime     @default(now()) @map("application_date") @db.DateTime
  // Relations
  user             User         @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_Apps_Users")
  organization     Organization @relation(fields: [organizationId], references: [id], onUpdate: NoAction, map: "FK_Apps_Orgs")

  // Updated with onDelete: NoAction to prevent SQL Server Cyclic Dependency errors
  manager        Employee? @relation("ManagerRole", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Apps_Manager")
  operationsHead Employee? @relation("OperationsHeadRole", fields: [operationsHeadId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Apps_OpsHead")
  adminHead      Employee? @relation("AdminHeadRole", fields: [adminHeadId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Apps_AdminHead")

  // Tracking & Modules
  history             ApplicationTrackingHistory[]
  trainingDetails     OrganizationTrainingDetail[]
  guardEducationStats GuardEducationLevelStat[]
  inspections         Inspection[]
  payments            Payment[]
  certifications      Certification[]
  agreements          Agreement[]

  @@map("applications")
}

model RenewalApplication {
  id                    Int      @id @default(autoincrement()) @map("renewal_application_id")
  organizationId        Int      @map("organization_id")
  type                  String?  @map("application_type") @db.VarChar(50)
  sourceCertificationId Int?     @map("source_certification_id")
  renewalYear           Int?     @map("renewal_year")
  createdAt             DateTime @default(now()) @map("created_at") @db.DateTime
  updatedAt             DateTime @updatedAt @map("updated_at") @db.DateTime

  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_RenewalApp_Organization")
  sourceCertification Certification? @relation("RenewalSourceCertification", fields: [sourceCertificationId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_RenewalApp_Cert")

  @@map("renewal_applications")
}

