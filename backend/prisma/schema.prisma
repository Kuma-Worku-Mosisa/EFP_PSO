model Faq {
  id              Int      @id @default(autoincrement()) @map("faq_id")
  categoryType    String   @map("category_type") @db.NVarChar(100)
  questionText    String   @map("question_text") @db.NVarChar(Max)
  questionTextAm  String?  @map("question_text_am") @db.NVarChar(Max)
  answerText      String   @map("answer_text") @db.NVarChar(Max)
  answerTextAm    String?  @map("answer_text_am") @db.NVarChar(Max)
  isPublished     Boolean  @default(true) @map("is_published")
  hitCount        Int      @default(0) @map("hit_count")
  createdByUserId Int?     @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.DateTime
  updatedAt       DateTime @default(now()) @map("updated_at") @db.DateTime

  creator User? @relation("FaqCreator", fields: [createdByUserId], references: [id], onUpdate: NoAction, map: "FK_Faq_Users")

  @@map("faqs")
}

model AuditLog {
  id Int @id @default(autoincrement()) @map("audit_log_id")

  // Who did it?
  userId Int? @map("user_id")

  // What action was taken? (e.g., "CREATE", "UPDATE", "DELETE", "LOGIN")
  action String @db.VarChar(50)

  // Which table/model was affected? (e.g., "Employee", "IncidentReport")
  entityName String @map("entity_name") @db.VarChar(100)

  // The ID of the specific record changed
  entityId Int? @map("entity_id")

  // Data changes stored as JSON (SQL Server supports this in VarChar(Max))
  // Values before the change
  oldValue String? @map("old_value") @db.VarChar(Max)
  // Values after the change
  newValue String? @map("new_value") @db.VarChar(Max)

  // Metadata for tracking
  ipAddress String?  @map("ip_address") @db.VarChar(50)
  userAgent String?  @map("user_agent") @db.VarChar(Max)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime

  // Relations
  // Use NoAction to ensure logs remain even if a user is deleted (Audit Integrity)
  user User? @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_AuditLogs_Users")

  @@map("audit_logs")
}

model PaymentTransaction {
  id            String   @id @default(uuid())
  outTradeNo    String   @unique // Keep this unique!
  transactionId String? // REMOVED @unique HERE so multiple PENDING entries can stay null
  amount        Decimal  @db.Decimal(10, 2)
  status        String   @default("PENDING")
  licenseId     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  refunds RefundLedger[]
}

model RefundLedger {
  id               String             @id @default(uuid())
  refundRequestNo  String             @unique // Generated tracking key (refund_request_no)
  telebirrRefundId String?            @unique // refund_order_id returned by Telebirr
  paymentId        String
  payment          PaymentTransaction @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  actualAmount     Decimal            @db.Decimal(10, 2)
  reason           String?
  status           String             @default("REFUNDING") // REFUNDING, REFUND_SUCCESS, REFUND_FAILED, REFUND_DUPLICATED
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Contact {
  id Int @id(map: "PK__contacts__contact_id") @default(autoincrement()) @map("contact_id")

  // Sender details
  senderName  String @map("sender_name") @db.NVarChar(255)
  senderEmail String @map("sender_email") @db.VarChar(255)
  subject     String @db.NVarChar(255)
  message     String @db.NVarChar(Max)

  // Department stored as a single column (no extra table needed)
  department String @db.VarChar(100)

  // Direct relationship to the department head (User)
  departmentHeadId Int  @map("department_head_id")
  departmentHead   User @relation(fields: [departmentHeadId], references: [id], onUpdate: NoAction, map: "FK_Contacts_DepartmentHead")

  // Tracking metadata
  status    String   @default("PENDING") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime

  @@map("contacts")
}

model RegularPeriodReport {
  id          Int    @id @default(autoincrement()) @map("period_report_id")
  reportTitle String @map("report_title") @db.NVarChar(255)

  // CHANGED: Replaced reportYear with a robust tracking Date
  reportDate DateTime @map("report_date") @db.Date

  // 1. Regular Reporting Period 
  reportingPeriod String @map("reporting_period") @db.VarChar(50)

  // --- PDF FILE ATTACHMENT STORAGE ---
  reportFileUrl String @map("report_file_url") @db.VarChar(255)

  // --- SYSTEM LINK RELATIONSHIPS ---
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Tracks which security agency user account created/logged the report
  userId Int?  @map("user_id")
  user   User? @relation("PeriodReportCreator", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // --- REPORTING SYSTEM ACTORS & SIGNATURE TRACKING ---

  // 2. Reporter: The Agency representative who compiles and uploads the period breakdown
  reporterName         String @map("reporter_name") @db.NVarChar(150)
  reporterTitle        String @map("reporter_title") @db.NVarChar(100)
  reporterJobResp      String @map("reporter_job_responsibility") @db.NVarChar(150)
  reporterSignatureUrl String @map("reporter_signature_url") @db.VarChar(255)

  // 3. Ethiopian Federal Police: The Officer/Professional receiving and reviewing the log
  efpOfficerName         String?   @map("efp_officer_name") @db.NVarChar(150)
  efpOfficerTitle        String?   @map("efp_officer_title") @db.NVarChar(100)
  efpOfficerJobResp      String?   @map("efp_officer_job_responsibility") @db.NVarChar(150)
  efpOfficerSignatureUrl String?   @map("efp_officer_signature_url") @db.VarChar(255)
  efpSignDate            DateTime? @map("efp_sign_date") @db.Date

  // 4. Normalized EFP Superior Relationship (Points to User model)
  superiorId Int?  @map("superior_id")
  superior   User? @relation("PeriodReportSuperior", fields: [superiorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Feedback specific metadata kept on the transaction report
  superiorName         String?   @map("superior_name") @db.NVarChar(150)
  superiorTitle        String?   @map("superior_title") @db.NVarChar(100)
  superiorSignatureUrl String?   @map("superior_signature_url") @db.VarChar(255)
  superiorFeedbackText String?   @map("superior_feedback_text") @db.NVarChar(Max)
  superiorSignDate     DateTime? @map("superior_sign_date") @db.Date

  // System Management Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("regular_period_reports")
}
