  transactionReference String    @unique @map("transaction_reference") @db.VarChar(100)
  status               String?   @map("payment_status") @db.VarChar(50)
  paymentDate          DateTime? @map("payment_date") @db.DateTime

  application Application? @relation(fields: [applicationId], references: [id], onUpdate: NoAction, map: "FK_Payments_Apps")

  @@map("payments")
}

model Certification {
  id                      Int       @id @default(autoincrement()) @map("certification_id")
  organizationId          Int?      @map("organization_id")
  applicationId           Int?      @map("application_id")
  signedByOfficialId      Int?      @map("signed_by_official_id")
  certificateSerialNumber String?   @unique @map("certificate_serial_number") @db.VarChar(100)
  level                   Int?      @map("certification_level")
  issueDate               DateTime  @map("issue_date") @db.Date
  expiryDate              DateTime  @map("expiry_date") @db.Date
  signedAt                DateTime? @map("signed_at") @db.DateTime
  stampedByUserId         Int?      @map("stamped_by_user_id")
  stampedAt               DateTime? @map("stamped_at") @db.DateTime
  qrCodeValue             String?   @unique @map("qr_code_value") @db.VarChar(255)
  status                  String?   @map("certification_status") @db.VarChar(50)

  organization        Organization?        @relation(fields: [organizationId], references: [id], onUpdate: NoAction, map: "FK_Certs_Orgs")
  stampedByUser       User?                @relation("CertificationStampedBy", fields: [stampedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Certs_StampedByUsers")
  application         Application?         @relation(fields: [applicationId], references: [id], onUpdate: NoAction, map: "FK_Certs_Apps")
  signedByOfficial    Official?            @relation(fields: [signedByOfficialId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_Certs_Officials")
  renewalApplications RenewalApplication[] @relation("RenewalSourceCertification")

  @@map("certifications")
}

// ==========================================
// 7. INCIDENT REPORTING 
// ==========================================

model IncidentReport {
  id             Int          @id @default(autoincrement()) @map("incident_report_id")
  fileNumber     String       @unique @map("file_number") @db.VarChar(50)
  reportDate     DateTime     @map("report_date") @db.Date
  organizationId Int          @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // 1. Service Receiver & Incident Core Metadata
  serviceReceiverName    String   @map("service_receiver_name") @db.NVarChar(255) // Client organization/individual who received the stolen service
  crimeType              String   @map("crime_type") @db.NVarChar(100) // Type of criminal act committed
  crimeInCapitalAmount   Decimal? @map("crime_in_capital_amount") @db.Decimal(18, 2) // Financial evaluation of the theft/crime in ETB
  incidentStartTimestamp DateTime @map("incident_start_timestamp") // Combines From Time, Day, and Year
  crimeCount             Int      @default(1) @map("crime_count")
  damageDescription      String   @map("damage_description") @db.NVarChar(Max) // Specific description of loss/damage rewritten directly to main table

  // 6, 7, 8. Personnel Headcounts Involved
  securityPersonnelCount         Int @default(0) @map("security_personnel_count")
  customerPersonnelCount         Int @default(0) @map("customer_personnel_count")
  otherPartiesCount              Int @default(0) @map("other_parties_count")
  SecurityCustomerOtherBodyCount Int @default(0) @map("security_customar_other_body_count")
  suspectedBodiesCount           Int @default(0) @map("suspected_bodies_count")

  // 9. Collusion & Status Metrics
  actionTakenStatus String  @map("action_taken_status") @db.NVarChar(Max) // Status of action taken
  explanation       String? @map("explanation") @db.NVarChar(Max)

  // --- REPORTING SYSTEM ACTORS & SIGNATURE TRACKING ---

  // 1. Reporter: The Agency User (e.g., Organization HR Manager or Supervisor) who fills and submits the form
  reporterName         String @map("reporter_name") @db.NVarChar(150)
  reporterTitle        String @map("reporter_title") @db.NVarChar(100)
  reporterJobResp      String @map("reporter_job_responsibility") @db.NVarChar(150)
  reporterSignatureUrl String @map("reporter_signature_url") @db.VarChar(255)

  // 2. Ethiopian Federal Police: The Officer/Professional receiving and auditing the submission
  efpOfficerName         String?   @map("efp_officer_name") @db.NVarChar(150)
  efpOfficerTitle        String?   @map("efp_officer_title") @db.NVarChar(100)
  efpOfficerJobResp      String?   @map("efp_officer_job_responsibility") @db.NVarChar(150)
  efpOfficerSignatureUrl String?   @map("efp_officer_signature_url") @db.VarChar(255)
  efpSignDate            DateTime? @map("efp_sign_date") @db.Date

  // 3. EFP Superior Feedback: Reviewing authority's directives
  superiorName         String?   @map("superior_name") @db.NVarChar(150)
  superiorTitle        String?   @map("superior_title") @db.NVarChar(100)
  superiorJobResp      String?   @map("superior_job_responsibility") @db.NVarChar(150)
  superiorFeedback     String?   @map("superior_feedback") @db.NVarChar(Max)
  superiorSignatureUrl String?   @map("superior_signature_url") @db.VarChar(255)
  superiorSignDate     DateTime? @map("superior_sign_date") @db.Date

  // --- SYSTEM LINK RELATIONSHIPS ---

  // FIXED: Explicitly named relation binding pointing to User.incidentReports
  userId   Int?              @map("user_id")
  user     User?             @relation("IncidentReporter", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  // One-to-Many Relationships to Child Tables
  suspects IncidentSuspect[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("incident_reports")
}

model IncidentSuspect {
  id               Int            @id @default(autoincrement()) @map("suspect_id")
  incidentReportId Int            @map("incident_report_id")
  incidentReport   IncidentReport @relation(fields: [incidentReportId], references: [id], onDelete: Cascade)

  // New Relation: Link directly to the active guard/employee profile if internal
  employeeId Int?      @map("employee_id")
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_IncidentSuspects_Employees")

  suspectName      String  @map("suspect_name") @db.NVarChar(150)
  relationToAgency String? @map("relation_to_agency") @db.NVarChar(200) // e.g., "Active Guard", "Fired Guard", "External Suspect"

  @@map("incident_suspects")
}

