# EFP PSO - Backend Environment Configuration
# Copy this file to .env and fill in your actual values
# ⚠️  NEVER commit .env file to version control

# ========================================
# DATABASE CONFIGURATION
# ========================================
# SQL Server connection string
# Format: sqlserver://user:password@host:port/database
DATABASE_URL="sqlserver://SA:YourPassword123@localhost:1433/efp_pso?encrypt=true&trustServerCertificate=false&connectionTimeout=30000"

# ========================================
# SERVER CONFIGURATION
# ========================================
# Port number for Express server
PORT=5000

# Node environment (development, production, test)
NODE_ENV=development

# ========================================
# AUTHENTICATION
# ========================================
# JWT secret key (minimum 32 characters, use a random string)
# Generate: openssl rand -base64 32
JWT_SECRET="your_random_jwt_secret_key_here_minimum_32_characters"

# JWT token expiration (e.g., "7d" for 7 days, "24h" for 24 hours)
JWT_EXPIRY="7d"

# ========================================
# EMAIL CONFIGURATION (Optional)
# ========================================
# SMTP host for sending emails
SMTP_HOST="smtp.gmail.com"

# SMTP port (usually 587 for TLS, 465 for SSL)
SMTP_PORT=587

# Email account for sending notifications
SMTP_USER="your-email@gmail.com"

# Email password or app-specific password
SMTP_PASSWORD="your-app-password-here"

# Email sender name
SMTP_FROM_NAME="EFP PSO System"

# ========================================
# FILE UPLOAD CONFIGURATION
# ========================================
# Maximum file size in bytes (10 MB = 10485760 bytes)
MAX_FILE_SIZE=10485760

# Upload directory (relative path)
UPLOAD_DIR="./uploads"

# ========================================
# EXTERNAL SERVICES
# ========================================

# TeleBirr payment integration (if applicable)
TELEBIRR_API_KEY="your_telebirr_api_key_here"

# ========================================
# LOGGING & MONITORING
# ========================================
# Log level (error, warn, info, debug)
LOG_LEVEL="info"

# Enable debug mode (true/false)
DEBUG="false"

# ========================================
# CORS CONFIGURATION
# ========================================
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:4173"

# ========================================
# SESSION CONFIGURATION
# ========================================
# Session secret for express-session
SESSION_SECRET="your_session_secret_key_here"

# Session timeout in milliseconds (24 hours = 86400000)
SESSION_TIMEOUT=86400000

# ========================================
# DATABASE BACKUP (Optional)
# ========================================
# Enable automated backups (true/false)
BACKUP_ENABLED="false"

# Backup schedule (cron format, e.g., "0 2 * * *" = 2 AM daily)
BACKUP_SCHEDULE="0 2 * * *"

# Backup storage path
BACKUP_PATH="./backups"

# ========================================
# RATE LIMITING (Optional)
# ========================================
# Enable rate limiting (true/false)
RATE_LIMIT_ENABLED="true"

# Requests per time window
RATE_LIMIT_MAX_REQUESTS=100

# Time window in minutes
RATE_LIMIT_WINDOW_MS=900000

# ========================================
# SECURITY
# ========================================
# HTTPS enabled (true/false) - set to true in production
HTTPS_ENABLED="false"

# SSL certificate path (if HTTPS_ENABLED=true)
SSL_CERT_PATH=""

# SSL key path (if HTTPS_ENABLED=true)
SSL_KEY_PATH=""

# Enable HSTS (HTTP Strict Transport Security)
HSTS_ENABLED="false"

# HSTS max age in seconds (default: 31536000 = 1 year)
HSTS_MAX_AGE=31536000

# ========================================
# ENVIRONMENT-SPECIFIC NOTES
# ========================================
# DEVELOPMENT:
#  - NODE_ENV=development
#  - DEBUG=true
#  - trustServerCertificate=true
#
# PRODUCTION:
#  - NODE_ENV=production
#  - DEBUG=false
#  - Use strong, unique JWT_SECRET
#  - Use verified SMTP credentials
#  - Enable HTTPS_ENABLED
#  - Set CORS_ORIGINS to actual domain
#  - Use environment-specific database
#
# TESTING:
#  - NODE_ENV=test
#  - Use test database (separate from production)
#  - DATABASE_URL points to test database
