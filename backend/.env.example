# Backend environment example for local development
# Copy this file to `.env` in the backend folder and edit values as needed.

# Server
PORT=5000
NODE_ENV=development

# Database (SQL Server)
DB_SERVER=localhost
DB_NAME=EFP_PSO
DB_USER=erpuser
DB_PASSWORD=123456

# Optional: override the base host used to generate QR verification links
# - For local development: leave unset or set to http://localhost:5000
# - For staging/prod: set to your public host (e.g., https://pso.efp.gov.et)
# Example for production:
# CERT_BASE_URL=https://pso.efp.gov.et
# Example for local testing:
# CERT_BASE_URL=http://localhost:5000
# Other env vars (JWT secrets, SSO, etc.) can go here as needed.
